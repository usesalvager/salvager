<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.salvager.watch</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/you/go/bin/salvager</string>
        <string>watch</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/path/to/your/project</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/you/Library/Logs/salvager.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/you/Library/Logs/salvager.err.log</string>
</dict>
</plist>
